# Toss Invest Open API credentials (WTS > 설정 > Open API)
# No quotes. Example: c_01HXYZ..., s_xxxxxxxx...
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=

# Default account seq from GET /api/v1/accounts
# Required for holdings/orders APIs. Example: 1
TOSS_ACCOUNT_SEQ=

# Express BFF port
PORT=3001

# (선택) AI 자동매매 판단용 Anthropic API 키. 설정 시 자동매매 패널의 'AI 판단' 토글 사용 가능.
# 미설정이면 AI 판단은 항상 '관망(HOLD)'으로 폴백한다. 호출당 비용이 발생하니 유의.
ANTHROPIC_API_KEY=