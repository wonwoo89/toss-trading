# Toss Invest Open API credentials (WTS > 설정 > Open API)
# No quotes. Example: c_01HXYZ..., s_xxxxxxxx...
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=

# Default account seq from GET /api/v1/accounts
# Required for holdings/orders APIs. Example: 1
TOSS_ACCOUNT_SEQ=

# Express BFF port
PORT=3001

# (선택) AI 자동매매 판단 — 아래 둘 중 하나만 설정하면 'AI 판단' 토글 사용 가능.
# 둘 다 없으면 AI 판단은 항상 '관망(HOLD)'으로 폴백한다.

# 방법 A: Anthropic API 키(종량제 과금, 호출당 비용 발생).
ANTHROPIC_API_KEY=

# 방법 B: Claude Pro/Max 구독으로 사용(과금 없음, 구독 사용량에서 차감).
# 로컬 PC에서 `claude setup-token` 실행 → 브라우저 승인 → 출력된 토큰(sk-ant-oat01-...)을 붙여넣기.
# 토큰은 1년 유효, 만료 시 같은 명령으로 재발급. 둘 다 설정하면 API 키가 우선.
CLAUDE_CODE_OAUTH_TOKEN=